      "seed": 105225548,
      "version": 988,
      "versionNonce": 2113396596,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1696339154428,
      "link": null,
      "locked": false,
      "text": "Data : \n\n\ntype ILivre = {\n    Identifiant unique du document\n    Titre\n    Année de publication\n    Éditeur\n    Référence unique\n    Catégorie (livre, périodique, etc.)\n    Auteur(s) (pour les livres)\n    Code ISBN (pour les livres) \n    Volume (pour les périodiques)\n    Numéro (pour les périodiques)\n    Code ISSN (pour les périodiques)\n}\n\ntype IBibliothécaire = {\n    Identifiant unique du bibliothécaire\n    Nom\n    Prénom\n    Position hiérarchique (stagiaire, bibliothécaire principal)\n    Autorisations (enregistrement d'emprunts, prolongation d'emprunts, interdiction temporaire d'emprunt)\n}\ntype IUser = {    \n    Nom,\n    Prénom,\n    Adresse,\n    Catégorie (utilisateurs occasionnels, abonnés, abonnés privilégiés),\n    Historique d'emprunt (une table associant les identifiants des utilisateurs avec \n    les identifiants des documents empruntés et les dates d'emprunt)\n    role: IRole\n}\n\ntype ISysteme = {\n    Historique des transactions (emprunts, retours, rappels, etc.)\n    Informations relatives aux utilisateurs\n    Informations relatives aux documents\n    Gestion des relances et des rappels\n}\n\ntype IAmende: {\n    Identifiant unique de l'amende\n    Identifiant unique de l'emprunt associé \n    Montant\n    Raison (document rendu en retard de plus de 3 niveaux)\n}\n\nenum iRole = \"default\" | \"sub\" | \"vip\"",
      "fontSize": 20,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 1171,
      "containerId": null,
      "originalText": "Data : \n\n\ntype ILivre = {\n    Identifiant unique du document\n    Titre\n    Année de publication\n    Éditeur\n    Référence unique\n    Catégorie (livre, périodique, etc.)\n    Auteur(s) (pour les livres)\n    Code ISBN (pour les livres) \n    Volume (pour les périodiques)\n    Numéro (pour les périodiques)\n    Code ISSN (pour les périodiques)\n}\n\ntype IBibliothécaire = {\n    Identifiant unique du bibliothécaire\n    Nom\n    Prénom\n    Position hiérarchique (stagiaire, bibliothécaire principal)\n    Autorisations (enregistrement d'emprunts, prolongation d'emprunts, interdiction temporaire d'emprunt)\n}\ntype IUser = {    \n    Nom,\n    Prénom,\n    Adresse,\n    Catégorie (utilisateurs occasionnels, abonnés, abonnés privilégiés),\n    Historique d'emprunt (une table associant les identifiants des utilisateurs avec \n    les identifiants des documents empruntés et les dates d'emprunt)\n    role: IRole\n}\n\ntype ISysteme = {\n    Historique des transactions (emprunts, retours, rappels, etc.)\n    Informations relatives aux utilisateurs\n    Informations relatives aux documents\n    Gestion des relances et des rappels\n}\n\ntype IAmende: {\n    Identifiant unique de l'amende\n    Identifiant unique de l'emprunt associé \n    Montant\n    Raison (document rendu en retard de plus de 3 niveaux)\n}\n\nenum iRole = \"default\" | \"sub\" | \"vip\"",
      "lineHeight": 1.2
    },
