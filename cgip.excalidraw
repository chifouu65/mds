    {
      "id": "4sGUL7Yt4c6IRCSD14Tz8",
      "type": "text",
      "x": -1348.0808439054317,
      "y": -619.9295626463273,
      "width": 1230.46875,
      "height": 1176,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
